[CustomMessages]
dotnetfx472_title=.NET Framework 4.7.2

en.dotnetfx472_size=110 MB
es.dotnetfx472_title=.NET Framework 4.7.2
es.dotnetfx472_size=110 MB

#ifdef dotnet_Passive
#define dotnetfx472_passive "'/passive '"
#else
#define dotnetfx472_passive "''"
#endif

[Code]
const
    dotnetfx472_url = 'https://go.microsoft.com/fwlink/?LinkId=863262';

procedure dotnetfx472();
var
    version: cardinal;
begin
    // Check if .NET 4.7.2 or higher is installed (release value >= 461808)
    if not RegQueryDWordValue(HKLM, 'SOFTWARE\Microsoft\NET Framework Setup\NDP\v4\Full', 'Release', version) then
        version := 0;
    
    // 461808 = .NET 4.7.2
    if version < 461808 then
        AddProduct('ndp472-kb4054530-web.exe',
            '/q ' + {#dotnetfx472_passive} + '/norestart',
            CustomMessage('dotnetfx472_title'),
            CustomMessage('dotnetfx472_size'),
            dotnetfx472_url, false, false);
end;